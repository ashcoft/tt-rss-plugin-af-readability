    {
    }

    class InvalidUriException extends \Exception implements UriException
    {
    }
}

namespace Uri\WhatWg
{
    final class InvalidUrlException extends \Uri\InvalidUriException
    {
    }

    final readonly class Url
    {
        /** @param list<UrlValidationError> $softErrors */
        public function __construct(string $uri, ?Url $baseUrl = null, &$softErrors = null)
        {
        }

        public function toAsciiString(): string
        {
        }
    }

    final readonly class UrlValidationError
    {
    }
}
